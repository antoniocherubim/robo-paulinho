# =============================================================================
# NBR 12721 — exemplo de configuracao (.env)
# Copie para .env e preencha:  cp .env.example .env
# =============================================================================

# --- Pastas e planilha (relativos a raiz do projeto) ---
PASTA_DOCS=data/input/documentos
PASTA_SAIDA=data/output/saida
PLANILHA=assets/ABNT_NBR_12721-2006.xlsx

# --- Logs (observabilidade) ---
PASTA_LOGS=logs
LOG_ARQUIVO=nbr12721.log
LOG_LEVEL=INFO

# --- OCR / PDF rasterizado ---
# Linux/macOS: normalmente basta deixar TESSERACT_CMD vazio se `tesseract` estiver no PATH.
# Windows: aponte para tesseract.exe, ex. C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=
TESSERACT_LANG=por+eng
LIMITE_CHARS_TEXTO_FILTRADO=16000

# Necessario pelo pdf2image principalmente no Windows, apontando para a pasta com pdftoppm.
# Exemplos:
# Windows: C:\poppler\Library\bin
# Linux: normalmente deixe vazio se `pdftoppm` estiver no PATH
POPPLER_PATH=

# --- Selecao do LLM (ver README secao "Configurar o LLM") ---
# anthropic = default; cadeia API -> Agent SDK -> CLI
# openai    = somente OpenAI API (estrito)
# auto      = tenta primario (LLM_AUTO_PRIMARY), depois secundario se falhar
LLM_PROVIDER=anthropic

# Ordem no modo auto (quando ambos os providers estao disponiveis)
LLM_AUTO_PRIMARY=anthropic

# -----------------------------------------------------------------------------
# Cenario A: Anthropic API (recomendado se voce tem chave da API)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# -----------------------------------------------------------------------------
# Cenario B: OpenAI API
# Descomente LLM_PROVIDER=openai no bloco acima (ou use LLM_PROVIDER=auto)
# OPENAI_MODEL: default do projeto e gpt-4o (override opcional)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# -----------------------------------------------------------------------------
# Cenario C: Claude CLI (plano Pro/Max, sem API key)
# Deixe ANTHROPIC_API_KEY vazio; LLM_PROVIDER=anthropic tenta CLI apos API/SDK
# Instale: npm install -g @anthropic-ai/claude-code  (ou script oficial)
# Login:    claude
# -----------------------------------------------------------------------------
# CLAUDE_EXECUTABLE=/caminho/completo/para/claude

# Paths extras para encontrar o executavel claude (separador: ; no Windows, : no Linux)
CLAUDE_EXTRA_PATHS=
CLAUDE_CANDIDATE_PATHS=
